# Copy to .env and fill in for your machine.  (.env is gitignored.)

# Host dir where your project files live (bind-mounted to /opt/workspace).
CLAUDE_WORK_DIR=/home/you/claude-work

# Host dir where Claude's durable state (config, auth, history, project trust)
# is persisted, kept separate from your project files. Defaults to
# ~/.local/state/iso-claude if unset.
#CLAUDE_STATE_DIR=/home/you/.local/state/iso-claude
