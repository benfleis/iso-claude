#!/usr/bin/env bash
# iso-firewall — reconcile the container's egress allowlist FROM THE HOST.
#
# Resolution happens here on the host, so the container never needs egress to
# (re)configure its own egress firewall (no bootstrap paradox). We compute the
# desired IP/CIDR set, diff it against the live `allowed-domains` ipset in the
# running container, and apply the difference atomically via `ipset restore`
# + `swap`. Running claude sessions are NOT interrupted (only the netfilter set
# contents change; the single iptables rule referencing it never moves).
#
# Fail-safe: if resolution looks degraded (GitHub meta unreachable, or the
# required anchor domain won't resolve) we ABORT and leave the live set intact,
# rather than push a set that would strip working egress.
#
# Usage:
#   iso-firewall            reconcile now (apply if changed)
#   iso-firewall --dry-run  report what WOULD change; exit 10 if changes pending
#   iso-firewall --quiet     suppress progress + the per-entry diff (errors still
#                            print to stderr); used by the iso-claude/iso-shell
#                            bootstrap so a cold start doesn't dump ~300 lines.
#
# Exit codes: 0 ok (applied or already in sync) · 10 changes pending (dry-run)
#             1 error (aborted, live set untouched)
set -euo pipefail
export LC_ALL=C # byte-order collation so `sort` and `comm` always agree

COMPOSE_DIR="${ISO_CLAUDE_DIR:-$HOME/src/iso-claude}"
COMPOSE_FILE="$COMPOSE_DIR/docker-compose.yaml"
ALLOWLIST="${ISO_ALLOWLIST:-$COMPOSE_DIR/allowlist.conf}"
SERVICE=claude
SET=allowed-domains
TMPSET=allowed-domains-tmp
REQUIRED_DOMAIN="api.anthropic.com" # losing this breaks Claude — never wipe it on a DNS blip

DRY_RUN=0
QUIET=0
for arg in "$@"; do
  case "$arg" in
  --dry-run) DRY_RUN=1 ;;
  -q | --quiet) QUIET=1 ;;
  *)
    echo "iso-firewall: unknown argument: $arg" >&2
    exit 2
    ;;
  esac
done
# log() prints informational progress to stdout unless --quiet; errors/warnings
# always go straight to stderr and are never suppressed.
log() { [ "$QUIET" = 1 ] || printf '%s\n' "$*"; }

dc() { docker compose -f "$COMPOSE_FILE" "$@"; }
exec_root() { dc exec -T --user 0 "$SERVICE" "$@"; }
# strip redundant /32 so a bare IP and x/32 compare equal, then sort-unique
normalize() { sed 's#/32$##' | sort -u; }

[ -f "$ALLOWLIST" ] || {
  echo "iso-firewall: no allowlist at $ALLOWLIST" >&2
  exit 1
}

# --- 1. Compute the desired set on the host -------------------------------
log "iso-firewall: resolving allowlist on host…"

CIDR_RE='^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+(/[0-9]+)?$'

# Published IPv4 range lists for CDN-fronted services. A domain like crates.io
# is GSLB/geo-balanced across whole CDNs — its IPs rotate (Fastly one query,
# CloudFront the next), so resolving the hostname can never pin it. Allow the
# provider's PUBLISHED ranges instead. These are CDN-WIDE (e.g. all of Fastly),
# trading breadth for reliability — opt in per source via @directives in the
# allowlist. A requested source that fails to fetch ABORTS (fail-safe: never
# strip working egress because a range list was momentarily unreachable).
fetch_source() {
  case "$1" in
  @github) curl -fsS --max-time 15 https://api.github.com/meta |
    jq -r '(.web + .api + .git)[]' ;;
  @fastly) curl -fsS --max-time 15 https://api.fastly.com/public-ip-list |
    jq -r '.addresses[]' ;;
  @cloudflare) curl -fsS --max-time 15 https://www.cloudflare.com/ips-v4 |
    tr -s ' \t\r' '\n' ;;
  @aws-cloudfront) curl -fsS --max-time 20 https://ip-ranges.amazonaws.com/ip-ranges.json |
    jq -r '.prefixes[] | select(.service=="CLOUDFRONT") | .ip_prefix' ;;
  *) return 2 ;;
  esac
}

pool=""
required_ok=0
while read -r entry; do
  [ -z "$entry" ] && continue
  case "$entry" in
  @*) # published-range directive
    ranges=$(fetch_source "$entry" | grep -E "$CIDR_RE" || true)
    if [ -z "$ranges" ]; then
      echo "iso-firewall: ABORT — range source $entry unknown or unavailable (live set left intact)" >&2
      exit 1
    fi
    pool+=$'\n'"$ranges"
    ;;
  *)
    if printf '%s' "$entry" | grep -qE "$CIDR_RE"; then
      pool+=$'\n'"$entry" # literal IP/CIDR — use verbatim
    else
      ips=$(dig +noall +answer +time=3 +tries=2 A "$entry" | awk '$4=="A"{print $5}')
      if [ -z "$ips" ]; then
        if [ "$entry" = "$REQUIRED_DOMAIN" ]; then
          echo "iso-firewall: ABORT — required domain $entry did not resolve (live set left intact)" >&2
          exit 1
        fi
        echo "iso-firewall: WARNING could not resolve $entry — skipping" >&2
        continue
      fi
      [ "$entry" = "$REQUIRED_DOMAIN" ] && required_ok=1
      pool+=$'\n'"$ips"
    fi
    ;;
  esac
done < <(sed -e 's/#.*//' -e 's/[[:space:]]//g' "$ALLOWLIST" | grep -v '^$')

if [ "$required_ok" -ne 1 ]; then
  echo "iso-firewall: ABORT — required domain $REQUIRED_DOMAIN not resolved from allowlist.conf (live set left intact)" >&2
  exit 1
fi

DESIRED=$(printf '%s\n' "$pool" | grep -v '^$' | normalize)
if [ -z "$DESIRED" ]; then
  echo "iso-firewall: ABORT — computed desired set is empty (live set left intact)" >&2
  exit 1
fi

# --- 2. Ensure container is up and scaffolding is in place ----------------
dc up -d >/dev/null
# Wait until boot scaffolding finished (avoids racing the entrypoint's ipset
# create / iptables setup). The match-set rule is added near the very end.
ready=0
for _ in $(seq 1 50); do
  if exec_root iptables -C OUTPUT -m set --match-set "$SET" dst -j ACCEPT >/dev/null 2>&1; then
    ready=1
    break
  fi
  sleep 0.2
done
[ "$ready" = 1 ] || {
  echo "iso-firewall: ABORT — firewall scaffolding not ready in container" >&2
  exit 1
}
exec_root ipset create "$SET" hash:net family inet -exist # defensive

# --- 3. Diff desired vs. live ---------------------------------------------
CURRENT=$(exec_root ipset save "$SET" | awk -v s="$SET" '$1=="add" && $2==s {print $3}' | normalize)
ADDED=$(comm -23 <(printf '%s\n' "$DESIRED") <(printf '%s\n' "$CURRENT"))
REMOVED=$(comm -13 <(printf '%s\n' "$DESIRED") <(printf '%s\n' "$CURRENT"))
n_desired=$(printf '%s\n' "$DESIRED" | grep -c . || true)
n_add=$(printf '%s' "$ADDED" | grep -c . || true)
n_rm=$(printf '%s' "$REMOVED" | grep -c . || true)

if [ "$n_add" -eq 0 ] && [ "$n_rm" -eq 0 ]; then
  log "iso-firewall: UNCHANGED ($n_desired entries)"
  exit 0
fi

log "iso-firewall: CHANGED (+$n_add -$n_rm → $n_desired entries)"
if [ "$QUIET" != 1 ]; then
  [ "$n_add" -gt 0 ] && printf '  + %s\n' $ADDED
  [ "$n_rm" -gt 0 ] && printf '  - %s\n' $REMOVED
fi

if [ "$DRY_RUN" = 1 ]; then
  log "iso-firewall: dry-run — not applied"
  exit 10
fi

# --- 4. Apply atomically: build staging set, swap in, drop staging --------
exec_root ipset destroy "$TMPSET" 2>/dev/null || true # clear any leftover
{
  echo "create $TMPSET hash:net family inet"
  while read -r net; do [ -n "$net" ] && echo "add $TMPSET $net"; done <<<"$DESIRED"
  echo "swap $TMPSET $SET"
  echo "destroy $TMPSET"
} | exec_root ipset restore -exist

# --- 5. Verify by diff (the invariant: live set == desired) ---------------
VERIFY=$(exec_root ipset save "$SET" | awk -v s="$SET" '$1=="add" && $2==s {print $3}' | normalize)
if [ "$VERIFY" != "$DESIRED" ]; then
  echo "iso-firewall: ERROR post-apply verify FAILED — live set != desired:" >&2
  diff <(printf '%s\n' "$DESIRED") <(printf '%s\n' "$VERIFY") >&2 || true
  exit 1
fi
log "iso-firewall: verified ($n_desired entries)"
